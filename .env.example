# ─────────────────────────────────────────────────────────────────────────────
# MindGuard — environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────
# Required — app will not start without these
# ─────────────────────────────────────────────
JWT_SECRET=                          # Generate: python -c "import secrets; print(secrets.token_hex(32))"
SUPABASE_URL=                        # Settings → API → Project URL
SUPABASE_ANON_KEY=                   # Settings → API → anon/public key


# ─────────────────────────────────────────────
# Hugging Face model
# ─────────────────────────────────────────────
HF_REPO_ID=kopiyodiana/mindguard-mental-roberta
HF_TOKEN=                            # Required only for private repos
HF_WEIGHTS_FILE=mindguard_best_weights.pt
HF_TOKENIZER_SUBFOLDER=mindguard_tokenizer
HF_CACHE_DIR=.cache/huggingface


# ─────────────────────────────────────────────
# Consent email delivery (optional)
# ─────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173   # Your public URL (e.g. https://your-app.up.railway.dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=


# ─────────────────────────────────────────────
# Data source API keys (optional)
# ─────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_API_KEY=


# ─────────────────────────────────────────────
# Legacy Streamlit app only (ignore for FastAPI)
# ─────────────────────────────────────────────
# SECRET_KEY=                        # Only used by auth.py (Streamlit), NOT by backend/auth.py
# GOOGLE_CLIENT_ID=                  # Only for Streamlit Google OAuth
# GOOGLE_CLIENT_SECRET=              # Only for Streamlit Google OAuth
# GOOGLE_REDIRECT_URI=               # Only for Streamlit Google OAuth
